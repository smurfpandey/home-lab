version: '3.2'

services:
  {{ hawser_service_name }}:
    image: {{ hawser_image_tag }}
    container_name: {{ hawser_service_name }}
    restart: unless-stopped
    ports:
      - "2376:2376"
    group_add:
      - "{{ hawser_docker_gid }}"
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock
    environment:
      - PORT=2376
      - AGENT_NAME={{ hawser_agent_name }}
