services:
  {{ m3u_editor_service_name }}:
    image: {{ m3u_editor_image }}
    container_name: {{ m3u_editor_service_name }}
    restart: unless-stopped
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.m3u-editor.rule=Host(`m3u-editor.{{ main_domain_name }}`)"
      - "traefik.http.routers.m3u-editor.entryPoints=websecure"
      - "traefik.http.routers.m3u-editor.tls=true"
      - "traefik.http.routers.m3u-editor.tls.certresolver={{ traefik_certresolver_name }}"
      - "traefik.http.services.m3u-editor.loadbalancer.server.port={{ m3u_editor_app_port }}"
    environment:
      - TZ=Europe/Dublin
      - APP_URL=https://m3u-editor.{{ main_domain_name }}
      - APP_PORT={{ m3u_editor_app_port }}
      - DB_CONNECTION=sqlite
      - ENABLE_POSTGRES=false
      - REDIS_HOST={{ earth_host }}
      - REDIS_SERVER_PORT={{ valkey_port }}
      - REDIS_PASSWORD={{ valkey_password }}
      - REDIS_DB={{ valkey_db_allocations.m3u_editor.default }}
      - REDIS_CACHE_DB={{ valkey_db_allocations.m3u_editor.cache }}
      - REDIS_IMPORT_DB={{ valkey_db_allocations.m3u_editor.import }}
      - REDIS_FILE_SYNC_DB={{ valkey_db_allocations.m3u_editor.file_sync }}
      - REDIS_SESSION_DB={{ valkey_db_allocations.m3u_editor.session }}
      - M3U_PROXY_ENABLED=false
      - M3U_PROXY_INTEGRATION_ENABLED=false
    volumes:
      - {{ m3u_editor_data_directory }}/config:/var/www/config
      - {{ m3u_editor_data_directory }}/storage:/var/www/html/storage/app/public
    networks:
      - {{ traefik_network_name }}

networks:
  {{ traefik_network_name }}:
    external: true
